### Create template
POST {{host}}/api/doclib/adv-workflows/templates
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Evidence Transfer",
  "category": "evidence_transfer",
  "stages": [
    {"name": "Supervisor", "type": "approval", "required_approvals": 1, "approvers": ["role:supervisor"], "sla_hours": 24},
    {"name": "Legal", "type": "review", "required_approvals": 1, "approvers": ["role:legal"], "sla_hours": 48},
    {"name": "Director", "type": "approval", "required_approvals": 2, "approvers": ["user:director", "user:deputy"], "sla_hours": 72}
  ],
  "escalation_rules": {"auto_escalate_after_hours": 96, "escalate_to": "user_director"}
}

### List templates
GET {{host}}/api/doclib/adv-workflows/templates
Authorization: Bearer {{token}}

### Start workflow
POST {{host}}/api/doclib/adv-workflows
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "template_id": "{{advTemplateID}}",
  "resource_id": "{{evidenceID}}",
  "resource_type": "evidence",
  "metadata": {"from_agency": "FBI", "to_agency": "SEC"}
}

### Get instance
GET {{host}}/api/doclib/adv-workflows/{{advInstanceID}}
Authorization: Bearer {{token}}

