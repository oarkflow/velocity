# Velocity Platform — HTTP Tests
# Use with VS Code REST Client extension or IntelliJ HTTP Client
# Variables: set {{host}} and {{token}} before running

@host = http://localhost:3000
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_TOKEN_HERE

### ============================================================
### 1. Organization Setup
### ============================================================

### Create company
POST {{host}}/api/doclib/orgs
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Federal Investigation Bureau",
  "description": "Law enforcement and intelligence agency"
}

### List companies
GET {{host}}/api/doclib/orgs
Authorization: Bearer {{token}}

### Create department
POST {{host}}/api/doclib/orgs/{{companyID}}/depts
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Financial Crimes Division",
  "code": "FCD",
  "head_user_id": "user_director01"
}

### List departments
GET {{host}}/api/doclib/orgs/{{companyID}}/depts
Authorization: Bearer {{token}}

### Create unit
POST {{host}}/api/doclib/depts/{{deptID}}/units
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "company_id": "{{companyID}}",
  "name": "Money Laundering Investigation Unit",
  "code": "MLIU",
  "manager_user_id": "user_manager01"
}

### Add member to unit
POST {{host}}/api/doclib/units/{{unitID}}/members
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "user_id": "user_agent007",
  "role": "senior_investigator"
}

### List unit members
GET {{host}}/api/doclib/units/{{unitID}}/members
Authorization: Bearer {{token}}

### Get user memberships
GET {{host}}/api/doclib/users/user_agent007/memberships
Authorization: Bearer {{token}}

### List all users
GET {{host}}/api/doclib/users
Authorization: Bearer {{token}}

### Remove member
DELETE {{host}}/api/doclib/units/{{unitID}}/members/user_agent007
Authorization: Bearer {{token}}

### ============================================================
### 2. Clearance & Policy
### ============================================================

### Set user clearance
PUT {{host}}/api/doclib/clearance/user_agent007
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "clearance_level": "secret",
  "granted_by": "user_director",
  "valid_from": "2026-01-01T00:00:00Z",
  "valid_to": "2027-01-01T00:00:00Z",
  "case_assignments": ["case_001"],
  "allowed_overlays": ["source_protected", "financial_confidential"]
}

### Get user clearance
GET {{host}}/api/doclib/clearance/user_agent007
Authorization: Bearer {{token}}

### Create access policy
POST {{host}}/api/doclib/policies
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Secret Document Access",
  "classification_level": "secret",
  "required_clearance": "secret",
  "required_overlays": ["need_to_know"],
  "require_case_membership": true
}

### Evaluate access
POST {{host}}/api/doclib/access/evaluate
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "user_id": "user_agent007",
  "resource_classification": "secret",
  "resource_case_id": "case_001",
  "overlays": ["source_protected"],
  "resource_type": "document",
  "resource_id": "doc_001"
}

### ============================================================
### 3. Documents
### ============================================================

### Create document (JSON)
POST {{host}}/api/doclib/documents
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Suspicious Activity Report - Case #4521",
  "description": "SAR for unusual wire transfers Jan-Mar 2026",
  "doc_type": "financial_report",
  "classification_level": "confidential",
  "owner_unit_id": "{{unitID}}",
  "owner_dept_id": "{{deptID}}",
  "owner_company_id": "{{companyID}}",
  "tags": ["aml", "wire_transfer", "suspicious"]
}

### Query documents
GET {{host}}/api/doclib/documents?classification=confidential&tags=aml&limit=20
Authorization: Bearer {{token}}

### Full-text search
GET {{host}}/api/doclib/documents?q=wire+transfer+suspicious&limit=50
Authorization: Bearer {{token}}

### Get document
GET {{host}}/api/doclib/documents/{{docID}}
Authorization: Bearer {{token}}

### Get document content
GET {{host}}/api/doclib/documents/{{docID}}/content
Authorization: Bearer {{token}}

### Update document
PUT {{host}}/api/doclib/documents/{{docID}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "SAR - Case #4521 (Updated)",
  "classification_level": "secret"
}

### Get related documents
GET {{host}}/api/doclib/documents/{{docID}}/related?limit=10
Authorization: Bearer {{token}}

### Add comment
POST {{host}}/api/doclib/documents/{{docID}}/comments
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "content": "Cross-referenced with Case #3892 — same shell company."
}

### List comments
GET {{host}}/api/doclib/documents/{{docID}}/comments
Authorization: Bearer {{token}}

### Delete document
DELETE {{host}}/api/doclib/documents/{{docID}}
Authorization: Bearer {{token}}

### ============================================================
### 4. Document Lifecycle
### ============================================================

### Transition status
PUT {{host}}/api/doclib/documents/{{docID}}/status
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "under_review",
  "comment": "Escalated for senior analyst review"
}

### Get history
GET {{host}}/api/doclib/documents/{{docID}}/history
Authorization: Bearer {{token}}

### ============================================================
### 5. Document Sharing
### ============================================================

### Create share (inter-department)
POST {{host}}/api/doclib/documents/{{docID}}/shares
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "grant_to_type": "department",
  "grant_to_id": "dept_legal",
  "permissions": ["read", "annotate"],
  "reason": "Legal review required",
  "expires_at": "2026-06-01T00:00:00Z"
}

### List shares
GET {{host}}/api/doclib/documents/{{docID}}/shares
Authorization: Bearer {{token}}

### Approve share
POST {{host}}/api/doclib/shares/{{shareID}}/approve
Authorization: Bearer {{token}}

### Reject share
POST {{host}}/api/doclib/shares/{{shareID}}/reject
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "reason": "Insufficient clearance level"
}

### Revoke share
DELETE {{host}}/api/doclib/shares/{{shareID}}
Authorization: Bearer {{token}}

### ============================================================
### 6. Audit & Access Chain
### ============================================================

### Get access chain
GET {{host}}/api/doclib/documents/{{docID}}/access-chain
Authorization: Bearer {{token}}

### Get access chain summary
GET {{host}}/api/doclib/documents/{{docID}}/access-chain/summary
Authorization: Bearer {{token}}

### ============================================================
### 7. Dispatch (Envelopes)
### ============================================================

### Send dispatch
POST {{host}}/api/doclib/documents/{{docID}}/dispatch
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "recipients": [
    {
      "name": "FinCEN Regulatory Office",
      "type": "government_agency",
      "address": "fincen-intake@treasury.gov"
    }
  ],
  "purpose": "Mandatory SAR filing",
  "case_ref": "case_001",
  "legal_note": "BSA/AML regulatory filing"
}

### List dispatches
GET {{host}}/api/doclib/documents/{{docID}}/dispatches
Authorization: Bearer {{token}}

### Get dispatch
GET {{host}}/api/doclib/dispatches/{{dispatchID}}
Authorization: Bearer {{token}}

### Acknowledge dispatch
POST {{host}}/api/doclib/dispatches/{{dispatchID}}/acknowledge
Authorization: Bearer {{token}}

### Recall dispatch
POST {{host}}/api/doclib/dispatches/{{dispatchID}}/recall
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "note": "Correction needed in transaction amounts"
}

### Get envelope
GET {{host}}/api/doclib/dispatches/{{dispatchID}}/envelope
Authorization: Bearer {{token}}

### ============================================================
### 8. Cases / Investigations
### ============================================================

### Create case
POST {{host}}/api/doclib/cases
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Operation Shadow Wire",
  "description": "Money laundering through shell companies in Panama",
  "case_type": "money_laundering",
  "priority": "critical",
  "department": "dept_fiu",
  "assigned_to": ["user_lead_inv", "user_analyst01"]
}

### Query cases
GET {{host}}/api/doclib/cases?status=investigation&type=money_laundering&priority=critical&limit=50
Authorization: Bearer {{token}}

### Get case
GET {{host}}/api/doclib/cases/{{caseID}}
Authorization: Bearer {{token}}

### Update case status
PUT {{host}}/api/doclib/cases/{{caseID}}/status
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "analysis"
}

### Link document to case
POST {{host}}/api/doclib/cases/{{caseID}}/documents
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "doc_id": "{{docID}}"
}

### Link entity to case
POST {{host}}/api/doclib/cases/{{caseID}}/entities
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "entity_id": "{{entityID}}"
}

### Link cases
POST {{host}}/api/doclib/cases/{{caseID}}/cases
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "linked_case_id": "case_3892"
}

### Add task
POST {{host}}/api/doclib/cases/{{caseID}}/tasks
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Trace beneficial ownership of ShellCorp LLC",
  "assigned_to": "user_analyst01",
  "priority": "high",
  "due_date": "2026-04-01T00:00:00Z"
}

### List tasks
GET {{host}}/api/doclib/cases/{{caseID}}/tasks
Authorization: Bearer {{token}}

### Add note
POST {{host}}/api/doclib/cases/{{caseID}}/notes
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "content": "Additional wire transfers totaling $2.3M discovered through Cyprus."
}

### List notes
GET {{host}}/api/doclib/cases/{{caseID}}/notes
Authorization: Bearer {{token}}

### Get timeline
GET {{host}}/api/doclib/cases/{{caseID}}/timeline
Authorization: Bearer {{token}}

### Find shared entities
GET {{host}}/api/doclib/cases/{{caseID}}/shared-entities?other_case_id=case_3892
Authorization: Bearer {{token}}

### ============================================================
### 9. Evidence & Chain of Custody
### ============================================================

### Collect evidence
POST {{host}}/api/doclib/evidence
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "case_id": "{{caseID}}",
  "type": "digital",
  "subtype": "bank_statement",
  "title": "HSBC Account Statements Q1 2026",
  "description": "Obtained via subpoena #SUB-2026-089",
  "source": "HSBC Legal",
  "classification": "confidential"
}

### Get evidence
GET {{host}}/api/doclib/evidence/{{evidenceID}}
Authorization: Bearer {{token}}

### Transfer custody
POST {{host}}/api/doclib/evidence/{{evidenceID}}/transfer
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "to_user": "user_forensic_analyst",
  "reason": "Forensic analysis of transaction patterns",
  "approval": "supervisor_ref_123"
}

### Get custody chain
GET {{host}}/api/doclib/evidence/{{evidenceID}}/custody
Authorization: Bearer {{token}}

### Verify integrity
GET {{host}}/api/doclib/evidence/{{evidenceID}}/verify
Authorization: Bearer {{token}}

### List case evidence
GET {{host}}/api/doclib/cases/{{caseID}}/evidence
Authorization: Bearer {{token}}

### ============================================================
### 10. Entities
### ============================================================

### Create person
POST {{host}}/api/doclib/entities/persons
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "John Doe",
  "aliases": ["J. Doe"],
  "nationality": "US",
  "risk_level": "high",
  "tags": ["suspect", "pep"]
}

### Create organization
POST {{host}}/api/doclib/entities/organizations
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "ShellCorp LLC",
  "type": "llc",
  "jurisdiction": "US-Delaware",
  "risk_level": "critical",
  "tags": ["shell_company"]
}

### Create account
POST {{host}}/api/doclib/entities/accounts
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "account_number": "****4521",
  "bank": "HSBC",
  "type": "corporate_checking",
  "currency": "USD"
}

### Create transaction
POST {{host}}/api/doclib/entities/transactions
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "type": "wire_transfer",
  "amount": 450000.00,
  "currency": "USD",
  "from_account": "ent_acct_4521",
  "to_account": "ent_acct_7890",
  "date": "2026-02-15T14:30:00Z",
  "suspicious": true
}

### Create event
POST {{host}}/api/doclib/entities/events
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "type": "suspicious_activity",
  "title": "Multiple rapid wire transfers",
  "occurred_at": "2026-02-15T14:30:00Z",
  "severity": "critical"
}

### Create location
POST {{host}}/api/doclib/entities/locations
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "ShellCorp Office",
  "address": "1209 Orange St, Wilmington, DE",
  "country": "US"
}

### Create device
POST {{host}}/api/doclib/entities/devices
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "type": "computer",
  "identifier": "MAC-AA:BB:CC:DD:EE:FF",
  "ip_address": "203.0.113.42"
}

### Create asset
POST {{host}}/api/doclib/entities/assets
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Luxury Yacht 'Sea Shadow'",
  "type": "vessel",
  "value": 2500000.00,
  "currency": "USD"
}

### Link entities
POST {{host}}/api/doclib/entities/link
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "source_id": "{{entityID1}}",
  "target_id": "{{entityID2}}",
  "relation_type": "beneficial_owner",
  "bidirectional": false,
  "metadata": {
    "ownership_percentage": "75"
  }
}

### Get entity with relations
GET {{host}}/api/doclib/entities/{{entityID}}?relations=true
Authorization: Bearer {{token}}

### Query entities by type
GET {{host}}/api/doclib/entities?type=person&limit=50
Authorization: Bearer {{token}}

### ============================================================
### 11. Graph Intelligence
### ============================================================

### Find path
GET {{host}}/api/doclib/graph/path?from={{entityID1}}&to={{entityID2}}&max_depth=5
Authorization: Bearer {{token}}

### Get neighborhood
GET {{host}}/api/doclib/graph/neighborhood/{{entityID}}?depth=3
Authorization: Bearer {{token}}

### Shortest path
GET {{host}}/api/doclib/graph/shortest-path?from={{entityID1}}&to={{entityID2}}&max_depth=6
Authorization: Bearer {{token}}

### Entity timeline
GET {{host}}/api/doclib/graph/timeline/{{entityID}}?from=2025-01-01T00:00:00Z&to=2026-12-31T23:59:59Z
Authorization: Bearer {{token}}

### Influence scores
GET {{host}}/api/doclib/graph/influence/{{entityID}}?entity_type=person&limit=20
Authorization: Bearer {{token}}

### Detect clusters
GET {{host}}/api/doclib/graph/clusters?entity_type=person&min_connections=3
Authorization: Bearer {{token}}

### Co-occurrences
GET {{host}}/api/doclib/graph/co-occurrences?entity_id={{entityID}}
Authorization: Bearer {{token}}

### Recurring patterns
GET {{host}}/api/doclib/graph/patterns?case_ids={{caseID1}},{{caseID2}}
Authorization: Bearer {{token}}

### Entity network
GET {{host}}/api/doclib/graph/network/{{entityID}}?depth=2
Authorization: Bearer {{token}}

### ============================================================
### 12. Visualization
### ============================================================

### Entity graph viz
GET {{host}}/api/doclib/viz/entity-graph/{{entityID}}?depth=3
Authorization: Bearer {{token}}

### Transaction flow viz
GET {{host}}/api/doclib/viz/transaction-flow/{{entityID}}?depth=3
Authorization: Bearer {{token}}

### Case map viz
GET {{host}}/api/doclib/viz/case-map/{{caseID}}
Authorization: Bearer {{token}}

### Document clusters
GET {{host}}/api/doclib/viz/doc-clusters
Authorization: Bearer {{token}}

### Investigation board
GET {{host}}/api/doclib/viz/investigation-board/{{caseID}}
Authorization: Bearer {{token}}

### ============================================================
### 13. Discovery / Search
### ============================================================

### Full search
POST {{host}}/api/doclib/discovery/search
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "text": "wire transfer shell company",
  "classification_levels": ["confidential", "secret"],
  "doc_types": ["financial_report"],
  "date_from": "2025-01-01T00:00:00Z",
  "date_to": "2026-12-31T23:59:59Z",
  "limit": 25
}

### Save query
POST {{host}}/api/doclib/discovery/queries
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Shell Company Docs",
  "description": "All docs mentioning shell companies",
  "query": {
    "text": "shell company beneficial owner",
    "classification_levels": ["confidential", "secret"]
  },
  "case_id": "{{caseID}}",
  "is_shared": true
}

### List saved queries
GET {{host}}/api/doclib/discovery/queries?case_id={{caseID}}
Authorization: Bearer {{token}}

### Execute saved query
POST {{host}}/api/doclib/discovery/queries/{{queryID}}/execute
Authorization: Bearer {{token}}

### Near-duplicates
GET {{host}}/api/doclib/discovery/near-duplicates/{{docID}}?threshold=0.7
Authorization: Bearer {{token}}

### Co-occurring entities
GET {{host}}/api/doclib/discovery/co-occurrences?min_count=2
Authorization: Bearer {{token}}

