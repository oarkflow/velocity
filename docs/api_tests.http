### ============================================================
### 15. Workflows
### ============================================================

### Create template
POST {{host}}/api/doclib/workflows/templates
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Document Classification Change",
  "steps": [
    {"name": "Supervisor Review", "approvers": ["role:supervisor"], "required_approvals": 1},
    {"name": "Security Officer", "approvers": ["role:security_officer"], "required_approvals": 1}
  ]
}

### List templates
GET {{host}}/api/doclib/workflows/templates
Authorization: Bearer {{token}}

### Start workflow
POST {{host}}/api/doclib/workflows
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "template_id": "{{templateID}}",
  "resource_type": "document",
  "resource_id": "{{docID}}",
  "data": {"justification": "Contains intel sources"}
}

### Get workflow instance
GET {{host}}/api/doclib/workflows/{{instanceID}}
Authorization: Bearer {{token}}

### Approve step
POST {{host}}/api/doclib/workflows/{{instanceID}}/approve
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "comment": "Approved"
}

### Reject step
POST {{host}}/api/doclib/workflows/{{instanceID}}/reject
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "reason": "Insufficient justification"
}

### ============================================================
### 16. ABAC Rules
### ============================================================

### Create rule (off-hours deny)
POST {{host}}/api/doclib/abac/rules
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Deny off-hours access",
  "effect": "deny",
  "priority": 100,
  "conditions": [
    {"attribute": "environment.hour", "operator": "gte", "value": "22"},
    {"attribute": "subject.role", "operator": "neq", "value": "admin"}
  ]
}

### List ABAC rules
GET {{host}}/api/doclib/abac/rules
Authorization: Bearer {{token}}

### Evaluate ABAC
POST {{host}}/api/doclib/abac/evaluate
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "subject": {"user_id": "user_agent007", "role": "investigator", "clearance": "secret"},
  "resource": {"doc_id": "doc_001", "classification": "confidential"},
  "action": "read",
  "environment": {"ip_address": "10.0.1.45", "hour": "14"}
}

### Delete ABAC rule
DELETE {{host}}/api/doclib/abac/rules/{{ruleID}}
Authorization: Bearer {{token}}

